        int len=nums.length;
        List<Integer> res=new ArrayList<>();
        for(int i=1;i<=len;i++){
        boolean isFound=false;
        for(int j=0;j<len;j++){
            if(nums[j]==i){
                isFound=true;
                break;
            }
        }
        if(!isFound){
            res.add(i);
        }
        }
