class Solution {
    public int[] sortByBits(int[] arr) {
        int n=arr.length;
        for(int i=0;i<n;i++){
            int count=Integer.bitCount(arr[i]);
            arr[i]+=count*100000;
        }
        Arrays.sort(arr);
        for(int i=0;i<n;i++){
            arr[i]%=100000;
        }
        return arr;
    }
}
Note: example arr = [3,1]
Binary:
3 → 11 → 2 ones
1 → 1  → 1 one
After modification:
3 → 3 + 2*100000 = 200003
1 → 1 + 1*100000 = 100001
Now array becomes:
[200003, 100001]
