class Solution {
    public int[] applyOperations(int[] nums) {
        for(int i= 0;i<nums.length-1;i++){
            if(nums[i]==nums[i+1]){
                nums[i]*=2;
                nums[i+1]=0;
            }
        }
        int index=0;
        for(int i=0;i<nums.length;i++){
            if(nums[i]!=0){
                nums[index++]=nums[i];
            }
        }
        while(index<nums.length){
            nums[index++]=0;
        }
        return nums;
    }
}
Note: here we have 2 parts and the second part is moving the zeros to the end and i did it using 2 pointers tecchnique
